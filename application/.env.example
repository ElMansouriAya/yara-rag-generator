# Flask Server Configuration
# ===================================
# Copy this file to .env and update values as needed

# Environment (development | production)
FLASK_ENV=development

# Server port
FLASK_PORT=5000

# Default LLM model (qwen | flan | mistral)
# - qwen (0.5B) — fastest, recommended for testing
# - flan (base) — good balance of speed/quality
# - mistral (7B) — best quality, slowest
DEFAULT_MODEL=qwen

# Optional: Custom dataset path (uses production dataset by default)
# DATASET_PATH=/path/to/custom/dataset.json

# Optional: Embedding model
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: Max tokens for LLM generation
# MAX_NEW_TOKENS=300

# Optional: LLM temperature (0.0-1.0)
# TEMPERATURE=0.3
